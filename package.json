{
  "name": "worktimetracker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm copy:sql-wasm && vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:mobile": "pnpm build && npx cap sync",
    "android:run": "bash -lc 'export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && nvm use v22 >/dev/null && pnpm build:mobile && npx cap run android'",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "pnpm copy:sql-wasm && vite build",
    "type-check": "vue-tsc --build",
    "copy:sql-wasm": "node ./scripts/copy-sql-wasm.mjs",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jeep-sqlite": "^2.8.0",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "sql.js": "1.11.0",
    "tsyringe": "^4.10.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "sql.js": "1.11.0"
    }
  }
}
